# Serve the production build from /dist/ for every request.
# This lets Plesk Git auto-deploy the whole repo into the docroot
# while the public site still loads compiled assets.

<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1. If the requested URL maps to a real file or directory under dist/,
  #    rewrite to that file. Covers /assets/*, /favicon.svg, /Logo-*.svg, etc.
  RewriteCond %{REQUEST_URI} !^/dist/
  RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f [OR]
  RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -d
  RewriteRule ^(.*)$ /dist/$1 [L]

  # 2. SPA fallback: anything else (react-router routes) returns dist/index.html.
  RewriteCond %{REQUEST_URI} !^/dist/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ /dist/index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Hashed assets are immutable — cache them aggressively.
  <FilesMatch "\.(js|css|woff2?|ttf|otf|eot|svg|png|jpg|jpeg|gif|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # index.html must always be revalidated so deploys take effect immediately.
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
